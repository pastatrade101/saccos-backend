NODE_ENV=development
PORT=5000
HOST=0.0.0.0
API_PREFIX=/api
BODY_LIMIT=1mb
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://saccos.makutano.co.tz

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-server-only-service-role-key
RECEIPTS_BUCKET=receipts
TEMP_PASSWORD_ENCRYPTION_KEY=replace-with-long-random-server-only-secret

SUBSCRIPTION_DEFAULT_GRACE_DAYS=7
HIGH_VALUE_THRESHOLD_TZS=2000000
OUT_OF_HOURS_START=18:00
OUT_OF_HOURS_END=07:00
OTP_REQUIRED_ON_SIGNIN=false
OTP_CODE_TTL_SECONDS=300
OTP_MAX_VERIFY_ATTEMPTS=5
OTP_SEND_RATE_LIMIT_MAX=5
OTP_SEND_RATE_LIMIT_WINDOW_MS=900000
OTP_RESEND_MAX=3
OTP_SMS_URL=https://messaging-service.co.tz/api/sms/v1/text/single
OTP_SMS_FROM=N-SMS
OTP_SMS_AUTHORIZATION=
OTP_SMS_BASIC_USERNAME=
OTP_SMS_BASIC_PASSWORD=
OTP_HASH_SECRET=replace-with-long-random-server-only-secret
PASSWORD_SETUP_REDIRECT_URL=http://localhost:5173/reset-password
REPORT_BRAND_NAME=SACCOS System
REPORT_BRAND_SUBTITLE=Official Financial Report
REPORT_BRAND_LOGO_PATH=../frontend/public/SACCOSS-LOGO.png
OBSERVABILITY_ENABLED=true
OBSERVABILITY_SAMPLE_LIMIT=500
METRICS_BEARER_TOKEN=
SLO_LIST_ENDPOINT_P95_MS=400
SLO_HEAVY_REPORT_P95_MS=2000
SLO_ERROR_RATE_PCT=1
SSL_ENABLED=true
LOG_LEVEL=info
IMPORTS_BUCKET=imports
MEMBER_IMPORT_RATE_LIMIT_MAX=3
MEMBER_IMPORT_RATE_LIMIT_WINDOW_MS=900000
AUTH_USER_CREATE_RATE_LIMIT_MAX=50
AUTH_USER_CREATE_RATE_LIMIT_WINDOW_MS=900000

BOOTSTRAP_INTERNAL_OPS_EMAIL=ops@example.com
